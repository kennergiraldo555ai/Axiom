# =============================================================================
# AXIOM — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# Server-only vars: keep them in .env.local, never prefix with NEXT_PUBLIC_
# Public vars: safe to expose to the browser, must prefix with NEXT_PUBLIC_
# =============================================================================

# ─── Supabase (required) ──────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → project → settings → API

# Public anon key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (required) ──────────────────────────────────────────────────────
# Get from: Supabase → project → settings → database → connection string
# Use the "Transaction" mode URL for DATABASE_URL (pooled)
# Use the "Session" mode URL for DIRECT_URL (direct, for migrations)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── AI (Phase 1+) ────────────────────────────────────────────────────────────
# Anthropic API key — used by the AI router. Set in Sprint 0.2+
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Places (Phase 2+) ─────────────────────────────────────────────────
# GOOGLE_PLACES_API_KEY=AIza...

# ─── Email OAuth (Phase 5+) ───────────────────────────────────────────────────
# GMAIL_CLIENT_ID=...
# GMAIL_CLIENT_SECRET=...

# ─── Observability (Phase 6+) ─────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_AUTH_TOKEN=...
